# =======================
# 用户主动要求排除的文件/目录
# =======================

# IDE / 编辑器配置
.idea/

# Python 编译产物与临时文件
__pycache__/
*.py[cod]
*$py.class
*.so

# Python 虚拟环境
.venv/
venv/
env/
ENV/

# 环境变量与敏感配置
backend-master/.env
vue3-element-admin-master/.env.development
vue3-element-admin-master/.env.production
ws-node/.env
ws-node/.env.development

# =======================
# 额外排除的文件/目录
# =======================

# 后端 SQLite 数据库（不建议推送到公共仓库）
backend-master/db.sqlite3
backend-master/db.sqlite3-journal

# 后端用户上传的媒体文件
backend-master/media/

# Node.js 依赖包（前端和 websocket 开发产生的依赖）
node_modules/

# 前端打包构建产物
vue3-element-admin-master/dist/
vue3-element-admin-master/dist-ssr/

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 操作系统自动生成的隐藏文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# VS Code 编辑器配置
.vscode/

# 测试覆盖率与构建缓存目录
coverage/
.nyc_output/
